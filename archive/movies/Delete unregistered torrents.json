{
  "_slug": "delete-unregistered-torrents-2",
  "name": "Delete: unregistered torrents",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "delete": {
      "enabled": true,
      "mode": "deleteWithFilesPreserveCrossSeeds",
      "condition": {
        "operator": "OR",
        "conditions": [
          {
            "operator": "AND",
            "conditions": [
              {
                "field": "IS_UNREGISTERED",
                "operator": "EQUAL",
                "value": "true"
              },
              {
                "field": "STATE",
                "operator": "NOT_EQUAL",
                "value": "tracker_down"
              }
            ]
          },
          {
            "operator": "AND",
            "conditions": [
              {
                "field": "STATE",
                "operator": "EQUAL",
                "value": "tracker_error"
              },
              {
                "field": "TRACKER",
                "operator": "EQUAL",
                "value": "BeyondHD"
              }
            ]
          }
        ]
      }
    }
  },
  "sortOrder": 6
}