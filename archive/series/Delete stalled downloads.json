{
  "_slug": "delete-stalled-downloads-2",
  "name": "Delete stalled downloads",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "delete": {
      "enabled": true,
      "mode": "deleteWithFilesIncludeCrossSeeds",
      "condition": {
        "operator": "AND",
        "conditions": [
          {
            "field": "ADDED_ON",
            "operator": "GREATER_THAN_OR_EQUAL",
            "value": "7200"
          },
          {
            "field": "PROGRESS",
            "operator": "LESS_THAN",
            "value": "0.095"
          },
          {
            "field": "STATE",
            "operator": "NOT_EQUAL",
            "value": "tracker_down"
          },
          {
            "operator": "OR",
            "conditions": [
              {
                "field": "STATE",
                "operator": "EQUAL",
                "value": "stalled_downloading"
              },
              {
                "field": "STATE",
                "operator": "EQUAL",
                "value": "uploading"
              }
            ]
          }
        ]
      }
    }
  },
  "intervalSeconds": 3600,
  "sortOrder": 10
}