{
  "_slug": "delete-unregistered-torrents-2",
  "name": "Delete: unregistered torrents",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "delete": {
      "enabled": true,
      "mode": "deleteWithFilesPreserveCrossSeeds",
      "condition": {
        "operator": "AND",
        "conditions": [
          {
            "field": "STATE",
            "operator": "NOT_EQUAL",
            "value": "tracker_down"
          },
          {
            "operator": "OR",
            "conditions": [
              {
                "operator": "AND",
                "conditions": [
                  {
                    "field": "IS_UNREGISTERED",
                    "operator": "EQUAL",
                    "value": "true"
                  }
                ]
              },
              {
                "operator": "AND",
                "conditions": [
                  {
                    "field": "STATE",
                    "operator": "EQUAL",
                    "value": "tracker_error"
                  },
                  {
                    "field": "TRACKER",
                    "operator": "EQUAL",
                    "value": "BeyondHD"
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "intervalSeconds": 900,
  "sortOrder": 6
}