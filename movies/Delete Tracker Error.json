{
  "_slug": "delete-tracker-error",
  "name": "Delete: Tracker Error",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "delete": {
      "enabled": true,
      "mode": "deleteWithFilesPreserveCrossSeeds",
      "condition": {
        "operator": "AND",
        "conditions": [
          {
            "field": "STATE",
            "operator": "EQUAL",
            "value": "tracker_error"
          },
          {
            "field": "STATE",
            "operator": "NOT_EQUAL",
            "value": "tracker_down"
          }
        ]
      }
    }
  },
  "intervalSeconds": 3600,
  "sortOrder": 11
}